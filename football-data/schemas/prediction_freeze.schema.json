{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "football-data/schemas/prediction_freeze.schema.json",
  "title": "Immutable Prediction Freeze",
  "type": "object",
  "required": ["freeze_id", "created_at_utc", "match_context", "calculation_output", "validation_report", "hashes"],
  "properties": {
    "freeze_id": {"type": "string", "pattern": "^[a-zA-Z0-9_.-]+$"},
    "created_at_utc": {"type": "string", "format": "date-time"},
    "match_context": {"type": "object"},
    "calculation_output": {"type": "object"},
    "validation_report": {"type": "object"},
    "hashes": {
      "type": "object",
      "required": ["match_context_sha256", "calculation_output_sha256", "validation_report_sha256", "freeze_payload_sha256"],
      "properties": {
        "match_context_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "calculation_output_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "validation_report_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "freeze_payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
