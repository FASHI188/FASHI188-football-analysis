{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "football-data/schemas/match_input.schema.json",
  "title": "Football Match Input",
  "type": "object",
  "required": ["competition_id", "home_team", "away_team", "kickoff_utc", "freeze_time_utc", "settlement"],
  "properties": {
    "competition_id": {"type": "string", "minLength": 1},
    "home_team": {"type": "string", "minLength": 1},
    "away_team": {"type": "string", "minLength": 1},
    "kickoff_utc": {"type": "string", "format": "date-time"},
    "freeze_time_utc": {"type": "string", "format": "date-time"},
    "settlement": {"const": "90_minutes_including_stoppage"},
    "competition_round": {"type": ["string", "null"]},
    "venue": {"type": ["string", "null"]},
    "neutral_venue": {"type": "boolean", "default": false},
    "two_legged": {"type": "boolean", "default": false},
    "first_leg_state": {
      "type": ["object", "null"],
      "properties": {
        "home_goals": {"type": "integer", "minimum": 0},
        "away_goals": {"type": "integer", "minimum": 0},
        "perspective": {"enum": ["current_home_team", "current_away_team"]}
      }
    },
    "market_snapshot": {"$ref": "market_snapshot.schema.json"},
    "lineup_evidence": {
      "type": ["object", "null"],
      "properties": {
        "status": {"enum": ["official", "probable", "unavailable"]},
        "observed_at_utc": {"type": ["string", "null"], "format": "date-time"},
        "sources": {"type": "array", "items": {"type": "string"}},
        "home_missing_players": {"type": "array", "items": {"type": "string"}},
        "away_missing_players": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": ["string", "null"]}
      },
      "required": ["status"]
    },
    "task_state": {
      "type": ["object", "null"],
      "properties": {
        "home": {"type": ["string", "null"]},
        "away": {"type": ["string", "null"]},
        "source": {"type": ["string", "null"]}
      }
    }
  },
  "additionalProperties": true
}
