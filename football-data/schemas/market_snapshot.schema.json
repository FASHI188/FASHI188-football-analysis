{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "football-data/schemas/market_snapshot.schema.json",
  "title": "Synchronized Market Snapshot",
  "type": ["object", "null"],
  "required": ["observed_at_utc", "sources"],
  "properties": {
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "observed_at_utc"],
        "properties": {
          "name": {"type": "string"},
          "group": {"type": ["string", "null"]},
          "url_or_reference": {"type": ["string", "null"]},
          "observed_at_utc": {"type": "string", "format": "date-time"},
          "tradable": {"type": "boolean", "default": true}
        }
      }
    },
    "one_x_two": {
      "type": ["object", "null"],
      "required": ["home", "draw", "away"],
      "properties": {
        "home": {"type": "number", "exclusiveMinimum": 1},
        "draw": {"type": "number", "exclusiveMinimum": 1},
        "away": {"type": "number", "exclusiveMinimum": 1}
      }
    },
    "asian_handicap": {
      "type": ["object", "null"],
      "required": ["line", "home", "away"],
      "properties": {
        "line": {"type": "number", "multipleOf": 0.25},
        "home": {"type": "number", "exclusiveMinimum": 1},
        "away": {"type": "number", "exclusiveMinimum": 1}
      }
    },
    "total_goals": {
      "type": ["object", "null"],
      "required": ["line", "over", "under"],
      "properties": {
        "line": {"type": "number", "multipleOf": 0.25},
        "over": {"type": "number", "exclusiveMinimum": 1},
        "under": {"type": "number", "exclusiveMinimum": 1}
      }
    },
    "btts": {
      "type": ["object", "null"],
      "required": ["yes", "no"],
      "properties": {
        "yes": {"type": "number", "exclusiveMinimum": 1},
        "no": {"type": "number", "exclusiveMinimum": 1}
      }
    }
  },
  "additionalProperties": true
}
