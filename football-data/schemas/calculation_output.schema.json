{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "football-data/schemas/calculation_output.schema.json",
  "title": "Formal Calculation Output Artifact",
  "type": "object",
  "required": ["schema_version", "freeze_context_hash", "module_states", "conclusions"],
  "properties": {
    "schema_version": {"type": "string"},
    "freeze_context_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "rule_version": {"type": "string"},
    "module_states": {
      "type": "object",
      "required": ["direct_total_goals", "conditional_goal_difference", "unified_score_matrix", "market_coordination"],
      "properties": {
        "direct_total_goals": {"enum": ["通过", "部分通过", "警告", "失败", "未启用", "不可用", "降级", "弃权", "不适用"]},
        "conditional_goal_difference": {"enum": ["通过", "部分通过", "警告", "失败", "未启用", "不可用", "降级", "弃权", "不适用"]},
        "unified_score_matrix": {"enum": ["通过", "部分通过", "警告", "失败", "未启用", "不可用", "降级", "弃权", "不适用"]},
        "market_coordination": {"enum": ["通过", "部分通过", "警告", "失败", "未启用", "不可用", "降级", "弃权", "不适用"]}
      }
    },
    "probabilities": {
      "type": ["object", "null"],
      "properties": {
        "one_x_two": {
          "type": ["object", "null"],
          "properties": {"home": {"type": "number"}, "draw": {"type": "number"}, "away": {"type": "number"}},
          "required": ["home", "draw", "away"]
        },
        "total_goals": {
          "type": ["object", "null"],
          "properties": {"0":{"type":"number"},"1":{"type":"number"},"2":{"type":"number"},"3":{"type":"number"},"4":{"type":"number"},"5":{"type":"number"},"6":{"type":"number"},"7+":{"type":"number"}},
          "required": ["0","1","2","3","4","5","6","7+"]
        },
        "btts_yes": {"type": ["number", "null"]},
        "score_matrix": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "required": ["home_goals", "away_goals", "probability"],
            "properties": {
              "home_goals": {"type": "integer", "minimum": 0},
              "away_goals": {"type": "integer", "minimum": 0},
              "probability": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        }
      }
    },
    "optimization_audit": {
      "type": ["object", "null"],
      "properties": {
        "prior_description": {"type": ["string", "null"]},
        "market_constraints": {"type": "array", "items": {"type": "string"}},
        "objective": {"type": ["string", "null"]},
        "constraint_form": {"type": ["string", "null"]},
        "converged": {"type": ["boolean", "null"]},
        "iterations": {"type": ["integer", "null"], "minimum": 0},
        "termination_reason": {"type": ["string", "null"]},
        "max_constraint_residual": {"type": ["number", "null"], "minimum": 0},
        "probability_sum": {"type": ["number", "null"]}
      }
    },
    "conclusions": {
      "type": "object",
      "required": ["result_text", "total_goals_text", "score_text", "final_line"],
      "properties": {
        "result_text": {"type": "string"},
        "total_goals_text": {"type": "string"},
        "score_text": {"type": "string"},
        "top_score": {"type": ["string", "null"], "pattern": "^\\d+-\\d+$"},
        "second_score": {"type": ["string", "null"], "pattern": "^\\d+-\\d+$"},
        "final_line": {"type": "string"}
      }
    }
  },
  "additionalProperties": true
}
