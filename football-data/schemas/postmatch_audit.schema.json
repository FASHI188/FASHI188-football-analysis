{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "football-data/schemas/postmatch_audit.schema.json",
  "title": "Immutable Postmatch Audit",
  "type": "object",
  "required": ["audit_id", "freeze_id", "result", "scores", "source_freeze_sha256"],
  "properties": {
    "audit_id": {"type": "string"},
    "freeze_id": {"type": "string"},
    "result": {
      "type": "object",
      "required": ["home_goals", "away_goals"],
      "properties": {
        "home_goals": {"type": "integer", "minimum": 0},
        "away_goals": {"type": "integer", "minimum": 0},
        "completed_at_utc": {"type": ["string", "null"], "format": "date-time"},
        "source": {"type": ["string", "null"]}
      }
    },
    "scores": {"type": "object"},
    "source_freeze_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
