{
  "schema_version": "V5.1.6-predictability-gate-config-r1",
  "purpose": "Strict chronological selective-1X2 abstention research using only pre-match formal-matrix uncertainty features.",
  "formal_weight": 0,
  "probability_change": false,
  "automatic_promotion": false,
  "target": "Increase accuracy of executed 1X2 directions through abstention, not by changing the unified score matrix.",
  "features": [
    "one_x_two_top1_probability",
    "one_x_two_top1_top2_gap",
    "one_x_two_normalized_entropy",
    "score_top3_cumulative_probability",
    "score_top1_top2_probability_gap",
    "total_top2_cumulative_probability",
    "total_normalized_entropy"
  ],
  "candidate_families": {
    "gap_only": {
      "gap_thresholds": [0.20, 0.25, 0.30, 0.35, 0.40]
    },
    "gap_result_entropy": {
      "gap_thresholds": [0.20, 0.25, 0.30, 0.35],
      "result_entropy_max": [0.95, 0.90, 0.85, 0.80, 0.75]
    },
    "gap_score_concentration": {
      "gap_thresholds": [0.20, 0.25, 0.30, 0.35],
      "score_top3_min": [0.25, 0.30, 0.35, 0.40]
    },
    "gap_total_concentration": {
      "gap_thresholds": [0.20, 0.25, 0.30, 0.35],
      "total_top2_min": [0.35, 0.40, 0.45, 0.50]
    },
    "gap_entropy_score": {
      "gap_thresholds": [0.20, 0.25, 0.30, 0.35],
      "result_entropy_max": [0.90, 0.85, 0.80],
      "score_top3_min": [0.25, 0.30, 0.35]
    }
  },
  "prior_selection_gate": {
    "pooled_selected_min": 100,
    "per_season_selected_min": 20,
    "pooled_accuracy_min": 0.68,
    "minimum_season_accuracy_min": 0.60,
    "season_accuracy_std_max": 0.10
  },
  "selection_order": [
    "highest_pooled_coverage",
    "highest_pooled_accuracy",
    "simpler_family",
    "lexicographic_rule_id"
  ],
  "forward_candidate_gate": {
    "evaluated_forward_folds_min": 2,
    "pooled_selected_min": 60,
    "pooled_accuracy_min": 0.70,
    "minimum_forward_season_accuracy_min": 0.60,
    "forward_accuracy_std_max": 0.10,
    "wilson_lower_reported": true
  },
  "governance": {
    "random_split": false,
    "target_season_outcome_used_for_rule_selection": false,
    "same_matrix_probability_mutation": false,
    "research_only": true,
    "existing_laliga_runtime_gate_unchanged": true
  }
}
