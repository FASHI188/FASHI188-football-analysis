{
  "schema_version": "V5.1.5-clubelo-residual-challenger-config-r1",
  "source": "http://api.clubelo.com",
  "source_contract": "Use rating whose From/To validity interval contains the calendar day strictly before the fixture date.",
  "domains": {
    "ENG_PremierLeague": "ENG",
    "ESP_LaLiga": "ESP",
    "GER_Bundesliga": "GER",
    "ITA_SerieA": "ITA",
    "FRA_Ligue1": "FRA"
  },
  "rating_scale": 400.0,
  "beta_profiles": [-0.50, -0.25, 0.00, 0.25, 0.50, 0.75, 1.00, 1.25, 1.50],
  "matrix_projection": {
    "type": "within_total_minimum_KL_exponential_tilt",
    "log_weight": "beta * ((home_elo-away_elo)/400) * (home_goals-away_goals)",
    "preserve_each_total_goal_marginal": true,
    "renormalize_within_each_total": true,
    "manual_home_advantage": false,
    "manual_expected_goals": false
  },
  "selection": {
    "strict_prior_seasons_only": true,
    "objective": "mean_1x2_rps + 0.25*mean_1x2_brier + 0.02*mean_joint_log",
    "minimum_prior_prediction_rows": 500,
    "tie_break": "smallest_absolute_beta_then_numeric_beta"
  },
  "forward_gate": {
    "minimum_evaluated_forward_folds": 2,
    "minimum_pooled_predictions": 500,
    "nonzero_beta_selected_in_each_last_two_forward_folds": true,
    "one_x_two_accuracy_nonworse": true,
    "one_x_two_brier_nonworse": true,
    "one_x_two_rps_nonworse": true,
    "joint_log_nonworse": true,
    "score_top1_nonworse": true,
    "score_top3_nonworse": true,
    "total_metrics_exactly_preserved": true,
    "probability_sum_tolerance": 1e-10,
    "total_marginal_tolerance": 1e-10
  },
  "identity_gate": {
    "normalized_exact_preferred": true,
    "minimum_similarity": 0.68,
    "minimum_best_second_margin": 0.08,
    "ambiguous_mapping": "FAIL_CLOSED"
  },
  "formal_weight": 0,
  "probability_change": false,
  "automatic_promotion": false,
  "promotion_note": "2025/26 has already been observed in other project research. Any positive result here remains shadow evidence; clean promotion requires untouched future chronological validation such as 2026/27."
}
