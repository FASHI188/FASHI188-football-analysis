{
  "schema_version": "V4.7.0-dynamic-strength-public-evidence-r1",
  "formal_weight": 0,
  "automatic_promotion": false,
  "purpose": "Competition-local, point-in-time-safe research inputs for the V4.7 adaptive commensurate-strength challenger. Route availability is not model activation.",
  "source": {
    "provider": "dcaribou/transfermarkt-datasets",
    "repository": "https://github.com/dcaribou/transfermarkt-datasets",
    "dataset_delivery_base": "https://pub-e682421888d945d684bcae8890b0ec20.r2.dev/data",
    "files": {
      "games": "games.csv.gz",
      "game_lineups": "game_lineups.csv.gz",
      "transfers": "transfers.csv.gz"
    },
    "refresh_cadence": "weekly_upstream",
    "role": "observed historical labels and dated transfer events only",
    "not_formal_pit_injury_source": true
  },
  "pit_policy": {
    "target_match_row_never_used_as_pre_match_manager_evidence": true,
    "manager_feature": "use only managers observed in completed matches strictly before target date",
    "lineup_feature": "use only actual starting lineups from completed matches strictly before target date",
    "transfer_feature": "use only transfer events with transfer_date strictly before target date",
    "predicted_lineups_never_written_as_observed": true,
    "same_competition_prior_only": true,
    "cross_competition_strength_borrowing": false,
    "future_season_or_future_match_usage": false
  },
  "feature_contract": {
    "roster_continuity": "prior-season starter-frequency weight still present after all dated in/out transfer events strictly before target date",
    "coach_continuity": "latest observed current-season manager before target equals terminal observed prior-season manager",
    "promoted_or_relegated": "team absent from immediately preceding competition season; prior-strength borrowing disabled when true",
    "structural_break_score": "capped unique dated transfer-movement players divided by twice the prior-season unique starter core size",
    "missing_feature_policy": "fail closed for that team-match; never insert a neutral default value"
  },
  "competition_mapping": {
    "ENG_PremierLeague": {"transfermarkt_competition_id": "GB1", "validation_route": "standard"},
    "GER_Bundesliga": {"transfermarkt_competition_id": "L1", "validation_route": "standard"},
    "ITA_SerieA": {"transfermarkt_competition_id": "IT1", "validation_route": "standard"},
    "FRA_Ligue1": {"transfermarkt_competition_id": "FR1", "validation_route": "standard"},
    "ESP_LaLiga": {"transfermarkt_competition_id": "ES1", "validation_route": "standard"},
    "POR_PrimeiraLiga": {"transfermarkt_competition_id": "PO1", "validation_route": "standard"},
    "NED_Eredivisie": {"transfermarkt_competition_id": "NL1", "validation_route": "standard_regular_league_only"},
    "SUI_SuperLeague": {"transfermarkt_competition_id": "C1", "validation_route": "split_stage_row_labels_required"},
    "SCO_Premiership": {"transfermarkt_competition_id": "SC1", "validation_route": "split_stage_row_labels_required"},
    "SWE_Allsvenskan": {"transfermarkt_competition_id": "SE1", "validation_route": "standard_regular_league_only"},
    "NOR_Eliteserien": {"transfermarkt_competition_id": "NO1", "validation_route": "standard_regular_league_only"},
    "JPN_J1": {"transfermarkt_competition_id": "JAP1", "validation_route": "j1_transition_barrier_required"},
    "KOR_KLeague1": {"transfermarkt_competition_id": "RSK1", "validation_route": "split_final_round_row_labels_required"},
    "BRA_SerieA": {"transfermarkt_competition_id": "BRA1", "validation_route": "standard"},
    "ARG_Primera": {"transfermarkt_competition_id": "ARG1", "validation_route": "apertura_clausura_stage_labels_required"},
    "USA_MLS": {"transfermarkt_competition_id": "MLS1", "validation_route": "regular_season_playoffs_separation_required"},
    "UEFA_ChampionsLeague": {"transfermarkt_competition_id": "CL", "validation_route": "main_tournament_qualifying_separation_required", "same_domain_prior_only": true}
  },
  "governance": {
    "research_only": true,
    "competition_specific_artifacts_required": true,
    "minimum_outer_time_folds_for_promotion_review": 8,
    "chronological_oof_required": true,
    "proper_scoring_required": ["joint_log_score", "1x2_brier", "1x2_rps", "total_goals_rps"],
    "matrix_noninferiority_required": ["top1", "top3", "top5", "score_set_80", "score_set_90", "probability_conservation"],
    "no_result_can_change_v470_formal_probabilities_without_current_compliant_promotion": true
  }
}
